# Supabase project settings — Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — used server-side only (overdue cron job). Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — used to send gate pass creation/approval/overdue email notifications
RESEND_API_KEY=

# Shared secret to authenticate Vercel Cron's call to /api/gate-pass/check-overdue
# Generate any random string, e.g.: openssl rand -hex 32
CRON_SECRET=

# Public URL of the deployed app — used to build links inside notification emails
# In production this can be left blank; Vercel's VERCEL_URL is used as a fallback
NEXT_PUBLIC_APP_URL=